{
  "name": "backend",
  "module": "server.js",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "NODE_ENV=production bun src/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,json}\"",
    "check": "bun run format:check && bun run lint",
    "fix": "bun run format && bun run lint:fix"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "logger": "^0.0.1",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}